# Field Review API Configuration

# ===== OPENAI (WHISPER API) =====
# Get your API key from: https://platform.openai.com/api-keys
# Required for audio transcription feature
OPENAI_API_KEY=sk-your-api-key-here

# ===== SERVER =====
PORT=3000
NODE_ENV=development

# ===== GOOGLE DRIVE (Optional) =====
# Set up OAuth credentials at: https://console.cloud.google.com
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ===== DROPBOX (Optional) =====
# Get app key from: https://www.dropbox.com/developers/apps
# DROPBOX_APP_KEY=your-app-key
# DROPBOX_APP_SECRET=your-app-secret

# ===== CORS =====
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://yourdomain.com

# ===== STORAGE =====
# Local file storage paths (relative to project root)
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
